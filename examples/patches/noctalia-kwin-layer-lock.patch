+bool LockSurface::initializeLayerShell(wl_output* output, std::int32_t scale) {
+  if (output == nullptr || renderContext() == nullptr || !m_connection.hasLayerShell()) {
+    return false;
+  }
+
+  if (!createWlSurface()) {
+    return false;
+  }
+  m_useLayerShell = true;
+  m_inputDispatcher.setTextInputContext(m_surface, m_connection.textInputService());
+
+  m_output = output;
+  m_connection.registerSurfaceOutput(m_surface, output);
+  setBufferScale(scale);
+
+  m_layerSurface = zwlr_layer_shell_v1_get_layer_surface(
+      m_connection.layerShell(), m_surface, output, static_cast<std::uint32_t>(LayerShellLayer::Overlay),
+      "noctalia-lockscreen"
+  );
+  if (m_layerSurface == nullptr) {
+    m_useLayerShell = false;
+    destroySurface();
+    return false;
+  }
+
+  if (zwlr_layer_surface_v1_add_listener(m_layerSurface, &kLayerLockSurfaceListener, this) != 0) {
+    zwlr_layer_surface_v1_destroy(m_layerSurface);
+    m_layerSurface = nullptr;
+    m_useLayerShell = false;
+    destroySurface();
+    return false;
+  }
+
+  m_connection.registerLayerSurface(m_surface, m_layerSurface);
+  zwlr_layer_surface_v1_set_anchor(
+      m_layerSurface,
+      LayerShellAnchor::Top | LayerShellAnchor::Bottom | LayerShellAnchor::Left | LayerShellAnchor::Right
+  );
+  zwlr_layer_surface_v1_set_size(m_layerSurface, 0, 0);
+  zwlr_layer_surface_v1_set_exclusive_zone(m_layerSurface, -1);
+  applyLayerKeyboardInteractivity();
+  wl_surface_commit(m_surface);
+
+  setRunning(true);
+  return true;
+}
+
+void LockSurface::applyLayerKeyboardInteractivity() {
+  if (!m_useLayerShell || m_layerSurface == nullptr) {
+    return;
+  }
+  const auto mode = m_locked ? LayerShellKeyboard::Exclusive : LayerShellKeyboard::None;
+  zwlr_layer_surface_v1_set_keyboard_interactivity(m_layerSurface, static_cast<std::uint32_t>(mode));
+  if (m_surface != nullptr) {
+    wl_surface_commit(m_surface);
+  }
+}
