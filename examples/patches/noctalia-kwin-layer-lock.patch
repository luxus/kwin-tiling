+void LockSurface::handleLayerConfigure(
+    void* data, zwlr_layer_surface_v1* layerSurface, std::uint32_t serial, std::uint32_t width, std::uint32_t height
+) {
+  auto* self = static_cast<LockSurface*>(data);
+  zwlr_layer_surface_v1_ack_configure(layerSurface, serial);
+  std::uint32_t resolvedWidth = width;
+  std::uint32_t resolvedHeight = height;
+  if (resolvedWidth == 0 || resolvedHeight == 0) {
+    if (const auto* output = self->m_connection.findOutputByWl(self->m_output); output != nullptr) {
+      if (resolvedWidth == 0) {
+        resolvedWidth = output->logicalWidth > 0 ? static_cast<std::uint32_t>(output->logicalWidth) : 1920u;
+      }
+      if (resolvedHeight == 0) {
+        resolvedHeight = output->logicalHeight > 0 ? static_cast<std::uint32_t>(output->logicalHeight) : 1080u;
+      }
+    } else {
+      if (resolvedWidth == 0) {
+        resolvedWidth = 1920u;
+      }
+      if (resolvedHeight == 0) {
+        resolvedHeight = 1080u;
+      }
+    }
+  }
+  if (self->width() != resolvedWidth || self->height() != resolvedHeight) {
+    self->m_firstFrameRendered = false;
+  }
+  self->Surface::onConfigure(resolvedWidth, resolvedHeight);
+}
