+    m_onSessionLocked();
+  }
+  if (m_pendingAfterLocked) {
+    auto pending = std::move(m_pendingAfterLocked);
+    m_pendingAfterLocked = {};
+    DeferredCall::callLater(std::move(pending));
+  }
+}
