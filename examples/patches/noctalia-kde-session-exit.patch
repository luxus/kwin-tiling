+  constexpr auto kDbusInterface = "org.freedesktop.DBus";
+  const sdbus::ServiceName kDbusBusName{kDbusInterface};
+  const sdbus::ObjectPath kDbusObjectPath{"/org/freedesktop/DBus"};
+
+  struct KdeSessionExitTarget {
+    std::string_view service;
+    std::string_view path;
+    std::string_view interface;
+    std::string_view method;
+  };
+
+  [[nodiscard]] bool sessionBusNameHasOwner(sdbus::IConnection& connection, std::string_view name) {
+    auto proxy = sdbus::createProxy(connection, kDbusBusName, kDbusObjectPath);
+    bool hasOwner = false;
+    proxy->callMethod("NameHasOwner")
+        .onInterface(kDbusInterface)
+        .withArguments(std::string{name})
+        .storeResultsTo(hasOwner);
+    return hasOwner;
+  }
+
+  [[nodiscard]] bool requestKdeSessionExitTarget(sdbus::IConnection& connection, const KdeSessionExitTarget& target) {
+    if (!sessionBusNameHasOwner(connection, target.service)) {
+      return false;
+    }
+
+    auto proxy = sdbus::createProxy(
+        connection, sdbus::ServiceName{std::string{target.service}}, sdbus::ObjectPath{std::string{target.path}}
+    );
+    proxy->callMethod(std::string{target.method}).onInterface(std::string{target.interface});
+    kLog.info("logout: delegated to {}.{}", target.service, target.method);
+    return true;
+  }
+
+  // KWin alone is not enough: needs ksmserver plus plasma-shutdown (org.kde.Shutdown) and/or
+  // ksmserver-logout-greeter (org.kde.LogoutPrompt). kwin-only sessions fall back to logind.
+  [[nodiscard]] bool requestKdeSessionExit() {
+    try {
+      auto connection = sdbus::createSessionBusConnection();
+      static constexpr std::array targets = {
+          KdeSessionExitTarget{"org.kde.Shutdown", "/Shutdown", "org.kde.Shutdown", "logout"},
+          KdeSessionExitTarget{"org.kde.LogoutPrompt", "/LogoutPrompt", "org.kde.LogoutPrompt", "promptLogout"},
+      };
+      for (const auto& target : targets) {
+        if (requestKdeSessionExitTarget(*connection, target)) {
+          return true;
+        }
+      }
+    } catch (const sdbus::Error& e) {
+      kLog.warn("logout: KDE session D-Bus delegation failed: {}", e.getMessage());
+    }
+    return false;
+  }
